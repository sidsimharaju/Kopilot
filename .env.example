# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─── Google Drive MCP ─────────────────────────────────────────
# Replaces the full Google OAuth2 app setup.
# Get these from claude.ai → Settings → Integrations → Google Drive
# → Connection URL and OAuth access token
GOOGLE_DRIVE_MCP_URL=https://mcp.googleapis.com/...
GOOGLE_DRIVE_MCP_TOKEN=ya29.your_oauth_token_here

# ─── Atlassian ───────────────────────────────────────────────
# Get token from https://id.atlassian.com/manage-profile/security/api-tokens
# If not set, people search falls back to Claude simulation.
ATLASSIAN_DOMAIN=yoursite.atlassian.net
ATLASSIAN_EMAIL=your_email@company.com
ATLASSIAN_API_TOKEN=your_atlassian_api_token_here

# ─── Server ──────────────────────────────────────────────────
PORT=3000
